<!DOCTYPE html>
<html>
  <head>
    <title>OpenBuffet</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application" %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  </head>

  <body>

    <header class="p-3 text-bg-dark">

      <div class="container">
        <div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
          <%= link_to(root_path, class: 'd-flex align-items-center mb-2 mb-lg-0 text-white text-decoration-none') do %>
            <h1>Buffet Livre</h1>
          <% end %>


            <ul class="nav col-12 col-lg-auto me-lg-auto mb-2 justify-content-center mb-md-0">
              <li><%= link_to "Home", root_path, class: "nav-link px-2 text-white" %></li>
            </ul>


            <% unless request.path.include?("new") || request.path.include?("edit") || request.path.include?("sign") || request.method != "GET" %>
              <%= form_with url: search_buffet_registrations_path, method: :get, class: 'col-12 col-lg-auto mb-3 mb-lg-0 me-lg-3' do |form| %>
                <%= form.search_field :search, class: 'form-control form-control-dark text-bg-dark', 'aria-label': 'Search', placeholder: "Nome, Cidade, Festas"%>
                <%= form.submit 'Pesquisar' %>
              <% end %>
            <% end %>

            <div class="text-end">
              <% if user_signed_in? %>
                <%= current_user.description %>
                <%= button_to 'Sair', destroy_user_session_path, method: :delete %>
                
                <% if  current_user.company && current_user.buffet_registration && current_user.buffet_registration.id %>
                  <%= link_to 'Meu Buffet', buffet_registration_path(current_user.buffet_registration) %>
                <% end %>

                
                <% if current_user.company %>
                  <%= link_to 'Pedidos', orders_path %>
                <% else %>
                  <%= link_to 'Meus pedidos', orders_path %>
                <% end %>
                
              <% else %>
                <%= link_to 'Entrar', new_user_session_path, class: "btn btn-outline-light me-2" %>
                <%= link_to 'Registrar', new_user_registration_path, class: "btn btn-warning" %>
              <% end %>
            </div>
            
           
            
        </div>
      </div>

      
    </header>

    <main>

      

        <div>
          <%= alert %>   
          
          <% if notice.class == Array %>
            <ul>
              <h4>Há <%= notice.length %> erros encontrados: </h4>
            <% notice.each do |each_notice| %>
              <li> <%= each_notice %> </li>
            <% end %>
            </ul>
          <% else %>
            <%= notice %>
          <% end %>
          
        </div>

      <%= yield %>

      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    </main>
  </body>
</html>
